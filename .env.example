TELEGRAM_BOT_TOKEN=put_your_token_here

# Limits
MAX_UPLOAD_MB=48
MAX_DURATION_SECONDS=1800
MAX_PARALLEL_DOWNLOADS=2
PER_USER_SINGLE_ACTIVE=1
MAX_QUALITY_BUTTONS=8

# Queue reliability
MAX_DOWNLOAD_ATTEMPTS=2
RETRY_BACKOFF_SECONDS=2
JOB_TIMEOUT_SECONDS=900

# yt-dlp
YTDLP_SOCKET_TIMEOUT=20
YTDLP_RETRIES=3
YTDLP_COOKIE_FILE=

# YouTube solver: off | deno_ejs
YOUTUBE_SOLVER_MODE=off
DENO_BIN=deno
DENO_SOLVER_SCRIPT=

# Runtime
TEMP_ROOT=/tmp/video_bot
LOG_LEVEL=INFO

# Healthcheck server
HEALTHCHECK_ENABLED=1
HEALTHCHECK_HOST=0.0.0.0
HEALTHCHECK_PORT=8080
